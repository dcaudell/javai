# Copy to .env before running `docker compose up` from this directory.

# Hugging Face model repo id. Qwen3-Embedding-0.6B is the Phase 0 reference/development model
# (whitepaper §4.5.1): Apache-2.0, CPU-friendly, 1024-dim output, part of a same-family size ladder
# (0.6B/4B/8B) so moving to a larger sibling later is a known-path model swap, not an architecture change.
JAVAI_EMBEDDING_MODEL_ID=Qwen/Qwen3-Embedding-0.6B

# Required, no default on purpose. Pin an exact model revision (a commit SHA, not a floating branch name)
# alongside the TEI image tag -- whitepaper §4.5.3: "pin the TEI image digest and model revision together
# ... so 'the same model' actually means the same weights." Look up the current revision at
# https://huggingface.co/Qwen/Qwen3-Embedding-0.6B/commits/main and paste the SHA here.
JAVAI_EMBEDDING_MODEL_REVISION=

# Host port the TEI REST API is published on.
JAVAI_EMBEDDING_PORT=8080
