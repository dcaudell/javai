  <artifactId>javai-annotations</artifactId>
  <packaging>jar</packaging>
  <name>JavAI Extensions -- Codegen Guidance</name>
  <description>Codegen Guidance and vectorization annotation vocabulary for JavAI Extensions (@Vectorize, @Summary, @Requires/@Ensures, and friends).</description>

  <!--
    Vector Core's and Vector Collections' vectorization/search-visibility annotations,
    plus Codegen Guidance's LLM/codegen-guidance annotations. Plain definitions, no
    processing logic — see doc/spec/vector-core.md, vector-collections.md,
