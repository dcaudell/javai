<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <!--
    Deliberately standalone: no parent POM, and not listed in the root pom.xml's modules. This is
    downstream client code exercising JavAI Extensions as a published dependency, not one of the eight
    Phase 0 reactor components SPEC.md describes. Run `mvn install` from the repo root first so
    io.github.dcaudell:javai-{annotations,vector,model,substrate}:0.1.0 are in the local repository;
    see README.md.
  -->
  <groupId>dev.xtrafe.javai.e2e</groupId>
  <artifactId>e2e-client-test</artifactId>
  <version>0.1.0</version>
  <packaging>jar</packaging>

  <name>JavAI Extensions -- End-to-End Client Test</name>
  <description>
    Standalone client project proving JavAI Extensions end to end: a real object graph (references and
    collections), real per-field/local/summary vectors, real embeddings from the Docker text-embeddings-
    inference container -- not a fake/hermetic provider. See README.md.
  </description>

  <properties>
    <maven.compiler.release>21</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

    <javai.version>0.1.0</javai.version>
    <junit.version>5.11.0</junit.version>
    <lombok.version>1.18.46</lombok.version>
    <!--
      Originally confirmed via `mvn dependency:tree -Dverbose` to fix a real, severe cross-version jackson
      mismatch caused by Testcontainers' own com.github.docker-java:docker-java-api hard-pinning
      jackson-annotations:2.10.3 at a shallower tree depth than the much newer jackson-databind/
      jackson-core/jackson-datatype-jsr310 versions javai-completion pulls in transitively via Spring AI
      (NoClassDefFoundError: com/fasterxml/jackson/annotation/JsonSerializeAs, at Hibernate's optional
      Jackson JSON format mapper). Testcontainers is gone from this module now, so that specific cause no
      longer applies; kept anyway as cheap, defensive version pinning across whatever else transitively
      touches Jackson (Spring AI, Hibernate).
    -->
    <jackson.version>2.22.1</jackson.version>

    <!--
      Empty default, not absent: LocalEmbeddingDefaults.preferOllama() treats a blank value the same as
      unset (falls back to host-OS detection), but an *absent* Maven property would make
      ${javai.embedding.provider} below resolve to the literal string "${javai.embedding.provider}"
      instead of interpolating to nothing. Override with `mvn test -Djavai.embedding.provider=ollama`
      (or `tei`) to force a choice regardless of host OS.
    -->
    <javai.embedding.provider></javai.embedding.provider>
  </properties>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>com.fasterxml.jackson</groupId>
        <artifactId>jackson-bom</artifactId>
        <version>${jackson.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <dependencies>
    <dependency>
      <groupId>io.github.dcaudell</groupId>
      <artifactId>javai-annotations</artifactId>
      <version>${javai.version}</version>
    </dependency>
    <dependency>
      <groupId>io.github.dcaudell</groupId>
      <artifactId>javai-vector</artifactId>
      <version>${javai.version}</version>
    </dependency>
    <dependency>
      <groupId>io.github.dcaudell</groupId>
      <artifactId>javai-model</artifactId>
      <version>${javai.version}</version>
    </dependency>
    <dependency>
      <groupId>io.github.dcaudell</groupId>
      <artifactId>javai-substrate</artifactId>
      <version>${javai.version}</version>
    </dependency>
    <!-- Agentic Supervision e2e proof (AgenticSupervisionE2ETest): its own independent weaver, installed
         alongside javai-substrate's in JavAIWeavingLauncherSessionListener for the same early-class-loading
         reason. -->
    <dependency>
      <groupId>io.github.dcaudell</groupId>
      <artifactId>javai-supervision</artifactId>
      <version>${javai.version}</version>
    </dependency>
    <dependency>
      <groupId>io.github.dcaudell</groupId>
      <artifactId>javai-collections</artifactId>
      <version>${javai.version}</version>
    </dependency>
    <dependency>
      <groupId>io.github.dcaudell</groupId>
      <artifactId>javai-persistence</artifactId>
      <version>${javai.version}</version>
    </dependency>
    <!-- Brings Spring AI + GSON in transitively (Maven's default compile scope is transitive to
         consumers); no separate BOM/version management needed here, same as javai-persistence already
         bringing in Hibernate/the Postgres driver above without re-declaring versions. -->
    <dependency>
      <groupId>io.github.dcaudell</groupId>
      <artifactId>javai-completion</artifactId>
      <version>${javai.version}</version>
    </dependency>

    <!-- Interop proof, not a general convenience dependency this project otherwise avoids: this module's
         domain classes are elsewhere hand-written specifically so their woven behavior is easy to read
         (see Attachment.java's javadoc, e.g.). Lombok is included here specifically to prove
         javai-substrate's load-time weaver interoperates with Lombok-generated bytecode (a conventional
         setXxx method, a constructor) the same as it does with hand-written code; see
         dev.xtrafe.javai.e2e.domain.Tag and LombokInteropE2ETest. `provided` scope: Lombok is a
         compile-time-only annotation processor with no runtime footprint of its own beyond the bytecode it
         generates into this module's own compiled classes. -->
    <dependency>
      <groupId>org.projectlombok</groupId>
      <artifactId>lombok</artifactId>
      <version>${lombok.version}</version>
      <scope>provided</scope>
    </dependency>

    <!-- Realistic-sounding (not random-noise) sample data for SampleDataSeeder/ArticleFixtures; chosen over
         Instancio specifically because semantic-similarity tests need real embeddable text signal, not
         type-correct-but-meaningless generated values. Compile scope, not test: both classes moved to
         src/main (dev.xtrafe.javai.e2e.fixtures) as part of centralizing mock-data seeding as a real
         responsibility of this module's main environment-setup code; a real trade-off worth stating
         plainly, since it means a "client" artifact now carries a fake-data-generation library as a real
         dependency, not just a test-scoped one. -->
    <dependency>
      <groupId>net.datafaker</groupId>
      <artifactId>datafaker</artifactId>
      <version>2.7.0</version>
    </dependency>

    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>
    <dependency>
      <!-- For JavAIWeavingLauncherSessionListener: needs to install the weaver before JUnit's own
           test discovery reflectively touches (and thereby unwovenly loads) the domain classes. -->
      <groupId>org.junit.platform</groupId>
      <artifactId>junit-platform-launcher</artifactId>
      <version>1.11.0</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <!--
            Confirmed empirically, not assumed: with this module's full dependency set on the classpath,
            javac's implicit "discover annotation processors via -classpath" fallback does not pick up
            Lombok; reproduced with a raw `javac -classpath <this module's full classpath>` invocation
            (no -processorpath), independent of Maven, which also silently skips Lombok and compiles Tag.java
            down to a bare class with only its declared fields and default constructor, no generated
            accessors. Making Lombok an explicit annotation processor path is the documented, deterministic
            fix (this is Lombok's own recommended Maven configuration, not a workaround specific to this
            project); it stops depending on javac's classpath-scanning fallback at all.
          -->
          <annotationProcessorPaths>
            <path>
              <groupId>org.projectlombok</groupId>
              <artifactId>lombok</artifactId>
              <version>${lombok.version}</version>
            </path>
          </annotationProcessorPaths>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.5.2</version>
        <configuration>
          <!--
            ByteBuddyAgent.install() self-attaches to this JVM to weave the domain classes below;
            disabled by default since JDK 9. Also give the first run generous room: JavAIEnvironment/
            MonolithicContainer builds a genuinely large custom image (Postgres+pgvector, Neo4j, and Ollama
            with its embedding model baked in) from scratch on a cold Docker build cache, but only ever
            once per machine now (see MonolithicContainer's own javadoc: it matches by container name, not
            Testcontainers' old image-hash reuse-matching, so a routine cache-drift rebuild can no longer
            silently duplicate the container the way it used to).

            The remaining variable this timeout has to absorb is LLM cold-load latency, not container
            rebuilds: five real qwen3:8b completions (CPU-bound inference inside the container, no GPU
            passthrough) measured ~1822s in one real run where the model wasn't already warm in Ollama's
            memory; once warm, the same five calls typically complete in a few seconds combined.
          -->
          <argLine>-Djdk.attach.allowAttachSelf=true</argLine>
          <forkedProcessTimeoutInSeconds>3600</forkedProcessTimeoutInSeconds>
          <!--
            Surefire does not forward -D properties from the `mvn` command line into the forked test JVM
            on its own; this is what actually makes `-Djavai.embedding.provider=...` reach
            LocalEmbeddingDefaults.
          -->
          <systemPropertyVariables>
            <javai.embedding.provider>${javai.embedding.provider}</javai.embedding.provider>
          </systemPropertyVariables>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
